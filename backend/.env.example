DATABASE_URL=sqlite:///./mathpath.db
SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
SEED_ON_STARTUP=true

# Live-safe readiness defaults. Keep strict readiness enabled unless doing controlled local QA.
TEMPORARY_ASSESSMENT_READINESS_BYPASS=false
ASSESSMENT_TESTING_OVERRIDE_ENABLED=false

# Optional local QA settings:
# TEMPORARY_ASSESSMENT_READINESS_BYPASS=true
# ASSESSMENT_TESTING_OVERRIDE_ENABLED=true
